<% layout('layouts/boilerplate') %>

<a href="/kcalog/logs/meals" class="btn btn-primary btn-lg">Meal Logs</a>
    
<a href="/kcalog/logs/workouts" class="btn btn-info btn-lg">workout Logs</a>

<h2 class="display-5 fw-semibold mt-0 mt-3">Daily Logs</h2>

<div class="d-flex flex-wrap justify-content-center">
    <% for (let dailyLog of allDailyLogs) { %>
        <section class="border border-secondary m-4 p-3 text-start" style="min-width:340px">
            <h3 class="fs-3"><%= dailyLog.calendarDate %></h3>
            <div class="row">
                <div class="col">
                    <p>Meal Kcal: <%= dailyLog.totalMealKcal %></p>
                    <p>Workout Kcal: <%= dailyLog.totalWorkoutKcal %></p>
                    <p>Kcal Balance: <%= dailyLog.kcalBalance %></p>
                    <a href="http://localhost:8080/kcalog/logs/<%= dailyLog._id %>" class="btn btn-secondary">View</a>
                </div>
            </div>
        </section>
    <% } %>
</div>
