<% layout('layouts/boilerplate') %>

<a href="/logs/workouts" class="btn btn-light">All Workout Logs</a>

<h1 class="display-5 fw-semibold my-3 text-capitalize"><%= workoutLog.name %></h1>

<a href="/logs/<%= workoutLog.dailyLog %>" class="btn btn-light btn-lg border fw-normal mb-3"><%= workoutLog.longDate %></a>

<img src="<%= workoutLog.image %>" alt="" class="my-3 d-block mx-auto">

<section class="border d-flex justify-content-around align-items-center p-3">
    <div class="col-4">
        <h2 class="display-5"><%= workoutLog.kcal %></h2>
        <p class="fw-bold text-muted">Kcal</p>
    </div>

    <div class="col-4">
        <% if (workoutLog.duration) { %>
            <h2 class="display-5"><%= workoutLog.duration %></h2>
        <% } else { %>
            <h2 class="display-5">-</h2>
        <% } %>
        <p class="fw-bold text-muted">Duration</p>
    </div>

    <div class="col-4">
        <% if (workoutLog.duration) { %>
            <h2 class="display-5"><%= workoutLog.kcalPerHour %></h2>
        <% } else { %>
            <h2 class="display-5">-</h2>
        <% } %>
        <p class="fw-bold text-muted">Kcal Per Hour</p>
    </div>
</section>

<% if (workoutLog.notes) { %>
    <h2 class="display-5 fw-normal mt-4 mb-3">Notes</h2>
    <p><%= workoutLog.notes %></p>
<% } %>

<a href= "/logs/workouts/<%= workoutLog._id %>/edit"   class="btn btn-secondary my-4">Edit</a>

<form action="/logs/workouts/<%= workoutLog._id %>?_method=DELETE" method="post" id="<%= workoutLog.name %> (Log)" class="delete-form">
    <button type="submit" class="btn btn-secondary">Delete</button>
</form>

<script src="/scripts/deleteForms.js"></script>