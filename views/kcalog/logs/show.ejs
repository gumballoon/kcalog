<% layout('layouts/boilerplate') %>

<h1 class="display-5 fw-semibold mb-3"><%= dailyLog.longDate %></h1>

<a href="/logs" class="btn btn-light btn-lg">All Daily Logs</a>

<img src="<%= dailyLog.image %>" alt="" class="d-block mx-auto my-3">

<section class="border d-flex justify-content-around align-items-center p-3">
    <div class="col-4">
        <h3 class="display-5"><%= dailyLog.totalMealKcal %></h3>
        <p class="fw-bold text-muted">Meal Kcal</p>
    </div>

    <div class="col-4">
        <h3 class="display-5"><%= dailyLog.totalWorkoutKcal %></h3>
        <p class="fw-bold text-muted">Workout Kcal</p>
    </div>

    <div class="col-4">
        <h3 class="display-5"><%= dailyLog.kcalBalance %></h3>
        <p class="fw-bold text-muted">Kcal Balance</p>
    </div>
</section>

<% if (dailyLog.mealLogs.length) { %>
    <h2 class="mt-3 pt-3">Meal Logs</h3>
    <div class="d-flex flex-wrap justify-content-center">
        <% for (let mealLog of dailyLog.mealLogs) { %>
            <section class="border border-secondary m-4 p-3 text-start col-10 col-md-5 col-xl-3">
                <h3 class="fs-3 text-capitalize"><%= mealLog.meal.name %></h3>
                <div class="row">
                    <div class="col d-flex flex-column justify-content-around py-2">
                            <p>Total Kcal: <span class="fw-semibold"><%= mealLog.kcal %></span></p>
                            <p>
                                <a href="/logs/meals/?category=<%= mealLog.category %>" class="text-capitalize btn btn-light"><%= mealLog.category %></a>
                            </p>
                    </div>
                    <img src="<%= mealLog.image %>" alt="<%= mealLog.name %>" class="img-fluid m-0 col-4">
                </div>
                <a href="/logs/meals/<%= mealLog._id %>" class="btn btn-secondary col-12 mt-2">View</a>
            </section>
        <% } %>
    </div>
<% } %>

<% if (dailyLog.workoutLogs.length) { %>
    <h2 class="mt-3 pt-3">Workout Logs</h3>
    <div class="d-flex flex-wrap justify-content-center">
        <% for (let workoutLog of dailyLog.workoutLogs) { %>
            <section class="border border-secondary m-4 p-3 text-start col-10 col-md-5 col-xl-3">
                <h3 class="fs-3 text-capitalize"><%= workoutLog.name %></h3>
                <div class="row">
                    <div class="col d-flex flex-column justify-content-around py-2">
                            <p>Kcal Burned: <span class="fw-semibold"><%= workoutLog.kcal %></span></p>
                            <% if (workoutLog.duration !== '00:00') { %>
                                <p>Duration: <span class="fw-semibold"><%= workoutLog.duration %></span></p>
                            <% } %>
                    </div>
                    <img src="<%= workoutLog.image %>" alt="<%= workoutLog.name %>" class="img-fluid m-0 col-4">
                </div>
                <a href="/logs/workouts/<%= workoutLog._id %>" class="btn btn-secondary col-12 mt-2">View</a>
            </section>
        <% } %>
    </div>
<% } %>