<% layout('layouts/boilerplate') %>

<h2 class="display-5 fw-semibold">Edit Ingredient</h2>

<form action="/kcalog/db/ingredients/<%= ingredient._id %>?_method=PUT" method="post">
    <div>
        <label for="name" class="d-block fs-3 my-3">Name</label>
        <input type="text" id="name" name="ingredient[name]" required class="w-50 mb-3 text-capitalize" value=<%= ingredient.name %>>
    </div>

    <div>
        <label for="category" class="d-block fs-3 my-3">Category</label>
        <select id="category" name="ingredient[category]" class="w-50 mb-3">
            <% for (let category of allCategories) { %>
                <% if (category === ingredient.category) { %>
                    <option selected value="<%= category %>"><%= category[0].toUpperCase() + category.slice(1) %></option>
                <% } else { %>
                    <option value="<%= category %>"><%= category[0].toUpperCase() + category.slice(1) %></option>
                <% } %>
            <% } %>
        </select>
    </div>

    <div>
        <label for="unit" class="d-block fs-3 my-3">Unit</label>
        <select id="unit" name="ingredient[unit]" class="w-50 mb-3 text-capitalize">
            <% for (let unit of ['gram', 'millilitre', 'piece']) { %>
                <option <%=  (unit === ingredient.unit) ? 'selected' : ''%> value="<%= unit.toLowerCase() %>"><%= unit %></option>
            <% } %>
        </select>
    </div>

    <div>
        <label for="kcalPerUnit" class="d-block fs-3 my-3">Kcal Per Unit</label>
        <input type="number" min="0" step="any" id="kcalPerUnit" name="ingredient[kcalPerUnit]" class="w-50 mb-3" value=<%= ingredient.kcalPerUnit %> required>
    </div>

    <button type="submit" class="btn btn-success mt-3">Update Ingredient</button>

</form>

<form action="/kcalog/db/ingredients">
    <button class="btn btn-danger mt-3">Return to Ingredients</button>
</form>