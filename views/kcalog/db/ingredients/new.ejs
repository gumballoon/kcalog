<% layout('layouts/boilerplate') %>

<h2 class="display-5 fw-semibold">New Ingredient</h2>

<form action="/kcalog/db/ingredients" method="post">
    <div>
        <label for="name" class="d-block fs-3 my-3">Name</label>
        <input type="text" id="name" name="ingredient[name]" required class="w-50 mb-3 text-capitalize">
    </div>

    <div>
        <label for="category" class="d-block fs-3 my-3">Category</label>
        <select id="category" name="ingredient[category]" class="w-50 mb-3 text-capitalize">
            <% for (let category of allCategories) { %>
                <option value="<%= category %>"><%= category %></option>
            <% } %>
        </select>
    </div>

    <div>
        <label for="unit" class="d-block fs-3 my-3">Unit</label>
        <select id="unit" name="ingredient[unit]" class="w-50 mb-3 text-capitalize">
            <% for (let unit of ['gram', 'millilitre', 'piece']) { %>
                <option value="<%= unit %>"><%= unit %></option>
            <% } %>
        </select>
    </div>


    <div>
        <label for="kcalPerUnit" class="d-block fs-3 my-3">Kcal Per Gram</label>
        <input type="number" min="0" step="any" id="kcalPerUnit" name="ingredient[kcalPerUnit]" class="w-50 mb-3" required>
    </div>

    <button type="submit" class="btn btn-success mt-3">Save Ingredient</button>
</form>

<a href="/kcalog/db/ingredients" class="btn btn-danger mt-3">All Ingredients</a>