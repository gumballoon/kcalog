<% layout('layouts/boilerplate') %>

<datalist id="ingredients-list">
    <% for (let ingredient of allIngredients) { %>
        <option value="<%= ingredient.name[0].toUpperCase() + ingredient.name.slice(1) %>"></option>
    <% } %>
</datalist>

<h2 class="display-5 fw-semibold">New Meal</h2>

<form id="meal-form" action="/kcalog/db/meals" method="post">
    <div class="border-bottom mx-auto pb-3">
        <label for="name" class="d-block fs-3 fw-semibold my-3">Name</label>
        <input type="text" id="name" name="meal[name]" class="col-8" required>
    </div>

    <div class="border-bottom col-10 mx-auto pb-3 mb-3">
        <h3 class="fw-semibold fs-3 my-3">Ingredients</h3>
        <p id="no-ingredient" class="text-danger d-none">Please insert at least one ingredient</p>

        <div id="meal-ingredients">
            <div class="ingredient border row align-items-center px-2 py-3 mb-3" data-index="0">
                <div class="btn btn-danger col-1 remove-ingredient">X</div>

                <div class="d-flex text-start col-7">
                    <label for="ingredient-0" class="mx-2">Name</label>
                    <input type="search" id="ingredient-0" name="meal[ingredients][0][name]" list="ingredients-list" class="col-10" required>
                </div>

                <div class="d-flex text-start col-4">
                    <label for="grams-0" class="mx-2">Grams</label>
                    <input type="number" id="grams-0" name="meal[ingredients][0][grams]" class="w-50" required>
                </div>
            </div>
        </div>
        
        <div id="add-ingredient" class="btn btn-light">Add Ingredient</div>
    </div>

    <div class="border-bottom col-10 mx-auto pb-3 mb-3">
        <label for="notes" class="d-block fs-3 fw-semibold my-3">Notes</label>
        <textarea id="notes" name="meal[notes]" class="col-12"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Save Meal</button>

</form>

<a href="http://localhost:8080/kcalog/db/meals" class="btn btn-danger mt-3">Return to Meals</a>

<script src="/scripts/meal.js"></script>