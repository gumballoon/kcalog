<% layout('layouts/boilerplate') %>

<datalist id="ingredients-list">
    <% for (let ingredient of allIngredients) { %>
        <option value="<%= ingredient.name[0].toUpperCase() + ingredient.name.slice(1) %>"></option>
    <% } %>
</datalist>

<h2 class="display-5 fw-semibold">Edit Meal</h2>

<form id="meal-form" action="/kcalog/db/meals/<%= meal._id %>?_method=PUT" method="post">
    <div class="border-bottom mx-auto pb-3">
        <label for="name" class="d-block fs-3 fw-semibold my-3">Name</label>
        <input type="text" id="name" name="meal[name]" class="col-8" required value="<%= meal.name %>">
    </div>

    <div class="border-bottom col-10 mx-auto pb-3 mb-3">
        <h3 class="fs-3 my-3">Ingredients</h3>
        <p id="no-ingredient" class="text-danger d-none">Please insert at least one ingredient</p>

        <div id="meal-ingredients">
            <% for (let i = 0; i < meal.ingredients.length; i++) { %>
                <div class="ingredient border row align-items-center px-2 py-3 mb-3" data-index="<%= i %>">
                    <div class="btn btn-danger col-1 remove-ingredient">X</div>
                    
                    <div class="d-flex text-start col-7">
                        <label for="ingredient-<%= i %>" class="mx-2">Name</label>
                        <input type="search" id="ingredient-<%= i %>" name="meal[ingredients][<%= i %>][name]" list="ingredients-list" class="col-10" required value="<%= meal.ingredients[i].name %>">
                    </div>
    
                    <div class="d-flex text-start col-4">
                        <label for="grams-<%= i %>" class="mx-2">Grams</label>
                        <input type="number" id="grams-<%= i %>" name="meal[ingredients][<%= i %>][grams]" class="w-50" required value="<%= meal.ingredients[i].grams %>">
                    </div>
                </div>
            <% } %>
        </div>
        <div id="add-ingredient" class="btn btn-light">Add Ingredient</div>
    </div>

    <div class="border-bottom col-10 mx-auto pb-3 mb-3">
        <label for="notes" class="d-block fs-3 fw-semibold my-3">Notes</label>
        <textarea id="notes" name="meal[notes]" class="col-12"><%= meal.notes %></textarea>
    </div>

    <button type="submit" class="btn btn-success">Update Meal</button>

</form>

<a href="http://localhost:8080/kcalog/db/meals" class="btn btn-danger mt-3">Return to Meals</a>

<script src="/scripts/meal.js"></script>